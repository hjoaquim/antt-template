# Postgres warehouse
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=warehouse
POSTGRES_USER=warehouse
POSTGRES_PASSWORD=warehouse

# Host port the warehouse is published on. Change if you already have a
# Postgres listening on 5432 (e.g. POSTGRES_HOST_PORT=15432).
POSTGRES_HOST_PORT=5432

# Host port the Airflow UI is published on.
AIRFLOW_HOST_PORT=8080

# Airflow admin (created on first boot)
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Airflow uses its own metadata DB inside the same Postgres instance.
AIRFLOW_DB=airflow
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow
